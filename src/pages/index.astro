    summary: 'Khảo sát tài liệu học thuật về ứng dụng AI trong an ninh mạng, kết hợp chiến lược tìm kiếm và đánh giá độ tin cậy nguồn.',
    insight: 'Tìm kiếm học thuật cần thu hẹp phạm vi, so sánh nguồn và kiểm tra tính cập nhật.',
    slug: 'academic-search'
  },
  {
    no: '03',
    label: 'Prompt Engineering',
    title: 'Kỹ năng viết prompt hiệu quả cho mô hình ngôn ngữ lớn',
    pdf: '/pdfs/bai3.pdf',
    tools: ['ChatGPT', 'Role prompting', 'Structured output'],
    summary: 'Thử nghiệm nhiều cấp độ prompt trên các tác vụ học tập như tóm tắt, giải thích khái niệm và tạo câu hỏi ôn tập.',
    insight: 'Prompt tốt là thiết kế nhiệm vụ: rõ vai trò, bối cảnh, định dạng và tiêu chí đánh giá.',
    slug: 'prompt-engineering'
  },
  {
    no: '04',
    label: 'Collaboration',
    title: 'Sử dụng công cụ hợp tác trực tuyến cho dự án nhóm',
    pdf: '/pdfs/bai4.pdf',
    tools: ['Trello', 'Google Docs', 'Google Drive', 'Google Meet'],
    summary: 'Tổ chức dự án nhóm bằng board công việc, tài liệu chung, không gian lưu trữ và quy trình cập nhật tiến độ.',
    insight: 'Hợp tác hiệu quả cần trạng thái công việc rõ ràng và quy trình cập nhật minh bạch.',
    slug: 'collaboration'
  },
  {
    no: '05',
    label: 'Creative AI',
    title: 'Sử dụng AI tạo sinh trong sáng tạo nội dung số',
    pdf: '/pdfs/bai5.pdf',
    tools: ['Claude', 'ChatGPT', 'Adobe Firefly', 'Canva AI'],
    summary: 'Tạo infographic về trí tuệ nhân tạo và tương lai việc làm, kết hợp AI tạo nội dung, phản biện, hình ảnh và bố cục.',
    insight: 'AI tăng tốc ý tưởng, nhưng sản phẩm tốt vẫn phụ thuộc vào lựa chọn và biên tập của con người.',
    slug: 'ai-content'
  },
  {
    no: '06',
    label: 'Responsible AI',
    title: 'Sử dụng AI có trách nhiệm trong học tập và nghiên cứu',
    pdf: '/pdfs/bai6.pdf',
    tools: ['Policy review', 'AI disclosure', 'Ethical analysis'],
    summary: 'Xây dựng bộ nguyên tắc cá nhân về sử dụng AI dựa trên minh bạch, kiểm chứng, liêm chính học thuật và trách nhiệm.',
    insight: 'Giá trị học tập nằm ở việc hiểu, kiểm chứng và chịu trách nhiệm với sản phẩm cuối cùng.',
    slug: 'responsible-ai'
  },
  {
    no: '07',
    label: 'AI Literature Review',
    title: 'Tổng quan tài liệu bằng công cụ AI Elicit/Consensus',
    pdf: '/pdfs/bai7.pdf',
    tools: ['Elicit', 'Consensus', 'Literature screening'],
    summary: 'Dùng công cụ AI để khảo sát nhanh tài liệu về màng graphene/graphene oxide cho khử mặn và lọc ion trong nước.',
    insight: 'AI hỗ trợ tăng tốc tổng quan tài liệu, nhưng quyết định chọn nguồn vẫn cần người học đánh giá lại.',
    slug: 'literature-review'
  }
];

const rubric = [
  ['Thiết kế & cấu trúc Portfolio', 'One-page portfolio có điều hướng cố định, hero rõ, 7 artifact, PDF gốc, tổng kết và đối chiếu rubric.'],
  ['Quản lý tệp và thư mục', 'Bài 01 trình bày thao tác quản lý file/folder trên Windows.'],
  ['Tìm kiếm & đánh giá thông tin', 'Bài 02 thể hiện chiến lược tìm kiếm học thuật và đánh giá nguồn.'],
  ['Viết Prompt hiệu quả', 'Bài 03 so sánh prompt cơ bản, cải tiến và nâng cao.'],
  ['Hợp tác trực tuyến', 'Bài 04 mô tả Trello, Google Docs, Drive và quy trình nhóm.'],
  ['Sáng tạo nội dung với AI', 'Bài 05 ghi lại quy trình tạo infographic bằng nhiều công cụ AI.'],
  ['AI có trách nhiệm', 'Bài 06 xây dựng nguyên tắc cá nhân và phân tích đạo đức học thuật.'],
  ['Tổng kết và đánh giá bản thân', 'Reflection section nêu kỹ năng, thách thức, bài học và định hướng ứng dụng.']
];
