        color: #4f6b87;
        font-size: 12px;
        font-weight: 700;
      }

      .mission-panel {
        border-radius: 30px;
        border: 1px solid rgba(0,122,255,.13);
        background:
          linear-gradient(180deg, rgba(255,255,255,.64), rgba(230,247,255,.48));
        box-shadow: inset 0 1px 0 rgba(255,255,255,.78);
        padding: 18px;
      }

      .panel-top {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        margin-bottom: 8px;
      }

      .panel-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 8px 11px;
        border: 1px solid rgba(0,122,255,.14);
        background: rgba(255,255,255,.72);
        color: #006cff;
        font-size: 11.5px;
        font-weight: 800;
        letter-spacing: .05em;
      }

      .panel-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 36px;
        padding: 0 12px;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(0,122,255,.12), rgba(0,215,255,.16));
        color: #005bd8;
        font-size: 12px;
        font-weight: 800;
        transition: transform .18s ease, background .18s ease;
      }
      .panel-cta:hover { transform: translateY(-1px); background: linear-gradient(135deg, rgba(0,122,255,.18), rgba(0,215,255,.24)); }

      .panel-line {
        display: grid;
        grid-template-columns: 84px 1fr;
        gap: 12px;
        padding: 13px 0;
        border-bottom: 1px solid rgba(0,122,255,.08);
      }
      .panel-line:last-child { border-bottom: 0; }
      .panel-key {
        color: #006cff;
        font-size: 11.2px;
        font-weight: 800;
        letter-spacing: .11em;
        text-transform: uppercase;
      }
      .panel-value { color: #526f8c; font-size: 13.5px; line-height: 1.6; }

      .principles-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 14px;
      }

      .principle {
        border-radius: 28px;
        padding: 20px;
        min-height: 210px;
        overflow: hidden;
      }

      .check {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 16px;
        color: #fff;
        background: linear-gradient(135deg, #007aff, #00d7ff);
        box-shadow: 0 14px 30px rgba(0,122,255,.23), inset 0 1px 0 rgba(255,255,255,.34);
        font-weight: 800;
        margin-bottom: 16px;
      }
      .principle strong { display: block; letter-spacing: -0.04em; line-height: 1.25; font-size: 17px; }
      .principle span { display: block; margin-top: 10px; color: #577491; font-size: 13.2px; line-height: 1.64; font-weight: 300; }

      .reflection-layout {
        display: grid;
        grid-template-columns: .86fr 1.14fr;
        gap: 18px;
      }

      .reflection-visual {
        position: relative;
        overflow: hidden;
        border-radius: var(--radius-3xl);
        padding: 34px;
        min-height: 380px;
        color: white;
        background:
          radial-gradient(circle at 18% 18%, rgba(113,239,255,.48), transparent 31%),
          radial-gradient(circle at 82% 22%, rgba(255,255,255,.22), transparent 24%),
          linear-gradient(135deg, #007aff 0%, #00c8ff 52%, #5f5cff 100%);
        box-shadow: 0 42px 110px rgba(0,122,255,.28), inset 0 1px 0 rgba(255,255,255,.34);
      }

      .reflection-visual::after {
        content: "";
        position: absolute;
        inset: auto -22% -30% -8%;
        height: 48%;
        background: rgba(255,255,255,.18);
        filter: blur(28px);
        border-radius: 50%;
      }

      .reflection-visual .mono { opacity: .82; font-size: 12px; }
      .reflection-visual h3 { margin: 20px 0 0; max-width: 420px; font-size: clamp(30px, 3.4vw, 44px); line-height: 1.08; letter-spacing: -0.066em; }

      .reflection-copy { display: grid; gap: 13px; }
      .reflection-copy p { margin: 0; color: #334f69; font-size: 15.55px; line-height: 1.82; font-weight: 300; letter-spacing: -0.012em; }

      .rubric-table { display: grid; gap: 11px; }
      .rubric-row {
        border-radius: 22px;
        padding: 16px;
        display: grid;
        grid-template-columns: 270px 1fr;
        gap: 16px;
      }
      .rubric-name { color: #102238; font-weight: 800; letter-spacing: -0.036em; }
      .rubric-note { color: #5b7895; line-height: 1.62; font-size: 14px; }

      .footer { padding: 48px 0 64px; }
      .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 18px;
        color: #6683a1;
        border-top: 1px solid rgba(0,122,255,.14);
        padding-top: 26px;
        font-size: 14px;
      }
      .footer a { color: #006cff; font-weight: 700; }

      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity .72s ease, transform .72s cubic-bezier(.2,.8,.2,1);
      }
      .reveal.is-visible { opacity: 1; transform: translateY(0); }

      @keyframes aurora {
        0% { transform: translate3d(-1.5%, -1%, 0) scale(1); opacity: .78; }
        100% { transform: translate3d(1.5%, 2%, 0) scale(1.045); opacity: .98; }
      }
      @keyframes floatA { 0%,100%{transform:translate3d(0,0,0) scale(1)} 50%{transform:translate3d(24px,-18px,0) scale(1.04)} }
      @keyframes floatB { 0%,100%{transform:translate3d(0,0,0) scale(1)} 50%{transform:translate3d(-22px,18px,0) scale(1.035)} }
      @keyframes floatC { 0%,100%{transform:translate3d(0,0,0) scale(1)} 50%{transform:translate3d(18px,-24px,0) scale(1.04)} }
      @keyframes floatD { 0%,100%{transform:translate3d(0,0,0) scale(1)} 50%{transform:translate3d(-14px,-10px,0) scale(1.035)} }
      @keyframes floatSoft { 0%,100%{transform:translate3d(0,0,0)} 50%{transform:translate3d(0,-8px,0)} }
      @keyframes slowSpin { to { transform: rotate(360deg); } }
      @keyframes gradientFlow { 0%{background-position:0% 50%} 100%{background-position:100% 50%} }

      @media (max-width: 1050px) {
        .topbar { grid-template-columns: max-content 1fr; border-radius: 28px; }
        .nav { display: none; }
        .top-action { justify-self: end; }
        .hero-grid, .section-head, .overview-grid, .mission-shell, .reflection-layout { grid-template-columns: 1fr; }
        .showcase { min-height: auto; }
        .workspace { position: relative; left: 0; bottom: auto; width: 100%; transform: none; margin-top: 20px; }
        .portrait-shell { position: relative; top: auto; right: auto; width: 100%; margin-bottom: 18px; }
        .portrait-chip { display: none; }
        .floating-card { display: none; }
        .toc { position: relative; top: 0; display: grid; grid-template-columns: repeat(2, 1fr); }
        .toc-title { grid-column: 1 / -1; }
        .mission-body { grid-template-columns: 1fr; }
        .mission-card[data-even="true"] .mission-panel { order: initial; }
        .principles-grid { grid-template-columns: repeat(2, 1fr); }
      }

      @media (max-width: 720px) {
        .container { width: min(100% - 28px, var(--container)); }
        .topbar { top: 10px; width: calc(100% - 20px); min-height: 62px; padding: 9px 10px; }
        .brand-meta { display: none; }
        .brand-mark { width: 38px; height: 38px; border-radius: 14px; }
        .top-action { display: none; }
        .hero { padding-top: 104px; }
        h1 { font-size: clamp(42px, 12vw, 64px); letter-spacing: -0.062em; }
        .lead { font-size: 15.8px; }
        .workspace, .mission-card, .glass-panel, .reflection-visual { border-radius: 30px; }
        .window-body, .mission-card, .glass-panel { padding: 20px; }
        .hero-note { grid-template-columns: 1fr; }
        .mini-stats, .quality-strip, .principles-grid { grid-template-columns: 1fr; }
        .mission-top { grid-template-columns: 1fr; }
        .mission-number { width: 92px; height: 92px; font-size: 30px; }
        .toc { grid-template-columns: 1fr; }
        .rubric-row { grid-template-columns: 1fr; }
        .footer-inner { flex-direction: column; align-items: flex-start; }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.001ms !important;
          animation-iteration-count: 1 !important;
          scroll-behavior: auto !important;
          transition-duration: 0.001ms !important;
        }
        .reveal { opacity: 1; transform: none; }
      }
    </style>
  </head>

  <body>
    <div class="progress" aria-hidden="true"></div>
    <div class="orb-field" aria-hidden="true"><span class="orb"></span><span class="orb"></span><span class="orb"></span><span class="orb"></span></div>

    <header class="topbar" aria-label="Thanh điều hướng chính">
      <a class="brand" href="#top" aria-label="Trở về đầu trang">
        <span class="brand-mark">Đ</span>
        <span class="brand-copy"><span class="brand-name">Trần Anh Đức</span><span class="brand-meta">Digital Portfolio · UET.A11</span></span>
      </a>
      <nav class="nav" aria-label="Mục lục nhanh">
        <a href="#overview">Tổng quan</a>
        <a href="#missions">7 bài chính</a>
        <a href="#ai">AI trách nhiệm</a>
        <a href="#reflection">Tổng kết</a>
        <a href="#rubric">Rubric</a>
      </nav>
      <a class="top-action" href={student.github} target="_blank" rel="noreferrer">GitHub ↗</a>
    </header>

    <main id="top">
      <section class="hero container">
        <div class="hero-grid">
          <div class="hero-copy reveal">
            <span class="eyebrow mono">Digital Portfolio · 7/7 artifacts · 2026</span>
            <h1><span class="gradient-text">Hành trình học tập số và ứng dụng AI</span></h1>
            <p class="lead">
              Portfolio này trình bày bảy bài thực hành chính như một hệ thống sản phẩm học tập hoàn chỉnh: nội dung rõ ràng, minh chứng PDF gốc, phản tư cá nhân và trải nghiệm xem được tối ưu như một website sản phẩm.
            </p>
            <div class="hero-note">
              <span class="hero-note-mark">01</span>
              <p>Định hướng thiết kế là <strong>premium product/editorial</strong>: đẹp bằng bố cục, ánh sáng, chữ, nhịp cuộn và glass có kiểm soát — không đánh đổi độ mượt để lấy hiệu ứng nặng.</p>
            </div>
            <div class="identity-row" aria-label="Thông tin sinh viên">
              <span class="pill">{student.name}</span>
              <span class="pill">MSSV {student.id}</span>
              <span class="pill">Lớp {student.className}</span>
              <span class="pill">{student.role}</span>
            </div>
            <div class="hero-actions">
              <a class="btn btn-primary" href="#missions">Khám phá portfolio →</a>
              <a class="btn btn-secondary" href="#rubric">Đối chiếu rubric</a>
            </div>
          </div>

          <div class="showcase reveal" style="transition-delay:.08s">
            <div class="halo" aria-hidden="true"></div>

            <div class="floating-card one">
              <div class="floating-card-title mono">design.signal</div>
              <div class="floating-card-copy">Blue-first liquid glass, typography gọn, motion tinh chỉnh cho cảm giác premium và mượt.</div>
            </div>

            <div class="portrait-shell">
              <div class="portrait-noise" aria-hidden="true"></div>
              <div class="portrait-card">
                <div class="portrait-image-wrap">
                  <picture>
                    <source srcset="/assets/avatar-duc.webp" type="image/webp" />
                    <img class="portrait-image" src="/assets/avatar-duc-optimized.png" alt="Ảnh đại diện phong cách anime của Trần Anh Đức" width="820" height="820" loading="eager" decoding="async" fetchpriority="high" />
                  </picture>
                </div>
                <div class="portrait-meta">
                  <span class="mono">profile.identity</span>
                  <strong>{student.name}</strong>
                  <p>Sinh viên năm nhất ngành Khoa học máy tính · thích hệ thống đẹp, mượt và có chiều sâu trải nghiệm.</p>
                </div>
              </div>
              <div class="portrait-chip left"><span class="mono">focus.mode</span><strong>UI / AI / hệ thống học tập số</strong></div>
              <div class="portrait-chip right"><span class="mono">artifact.count</span><strong>07 bài chính · đầy đủ minh chứng</strong></div>
            </div>

            <div class="workspace">
              <div class="window">
                <div class="window-bar">
                  <div class="dots" aria-hidden="true"><span class="dot"></span><span class="dot"></span><span class="dot"></span></div>
                  <div class="window-title mono">portfolio.control</div>
                </div>
                <div class="window-body mono">
                  <div class="code-line"><span class="prompt">$</span><span>init learning-portfolio --student "Trần Anh Đức"</span></div>
                  <div class="code-line"><span class="prompt">$</span><span>attach profile --avatar anime --mood premium</span></div>
                  <div class="code-line"><span class="prompt">$</span><span>render design --reference gitbook mintlify craft warp deno</span></div>
                  <div class="code-line"><span class="success">✓</span><span>ready_for_assessment <span class="comment"># 7 artifact, PDF gốc, reflection rõ ràng</span></span></div>
                  <div class="mini-stats">
                    {stats.map((item) => (
                      <div class="mini-stat">
                        <strong>{item.value}</strong>
                        <span>{item.label}</span>
                        <em>{item.detail}</em>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="overview" class="section container">
        <div class="section-head reveal">
          <div>
            <div class="kicker">Portfolio Intent</div>
            <h2>Một hồ sơ học tập số được thiết kế như sản phẩm.</h2>
          </div>
          <p>
            Website không chỉ gom các file bài tập, mà biến toàn bộ hành trình học tập thành một trải nghiệm có chủ đích: người xem hiểu nhanh, kiểm chứng được bằng PDF gốc và cảm nhận rõ năng lực số qua từng artifact.
          </p>
        </div>
        <div class="overview-grid">
          <div class="glass-panel reveal">
            <h3>Blue liquid glass, docs-style, coding vibe.</h3>
            <p>
              Giao diện lấy cảm hứng từ các website tài liệu và sản phẩm developer cao cấp: nền sáng xanh, glass trong, typography Lexend, terminal block tinh tế và animation được kiểm soát để không làm giảm độ mượt khi cuộn.
            </p>
            <div class="quality-strip">
              <div class="quality-item"><strong>Glass</strong><span>Trong, sâu, có highlight như chất liệu thật.</span></div>
              <div class="quality-item"><strong>Blue</strong><span>Đậm hơn nhưng vẫn sạch và học thuật.</span></div>
              <div class="quality-item"><strong>Motion</strong><span>Sinh động bằng transform/opacity.</span></div>
              <div class="quality-item"><strong>Docs</strong><span>Nội dung dễ scan, dễ kiểm chứng.</span></div>
            </div>
          </div>
          <div class="glass-panel reveal" style="transition-delay:.06s">
            <h3>Logic chấm điểm được đặt ngay trong cấu trúc UI.</h3>
            <p>
              Các phần chính bám sát đề bài: giới thiệu, sản phẩm học tập, sử dụng AI có trách nhiệm, tổng kết và đối chiếu rubric. Mỗi bài có tiêu đề, công cụ, nội dung, minh chứng, nhận xét cá nhân và nút mở PDF.
            </p>
          </div>
        </div>
      </section>

      <section id="missions" class="section container">
        <div class="section-head reveal">
          <div>
            <div class="kicker">Mission Index</div>
            <h2>7 bài chính đã hoàn thành.</h2>
          </div>
          <p>
            Mỗi bài được trình bày như một artifact độc lập trong một hệ thống portfolio thống nhất. Cách bố trí này giúp người chấm xem nhanh nội dung chính, đồng thời có thể mở PDF để kiểm tra chi tiết.
          </p>
        </div>
        <div class="mission-shell">
          <aside class="toc reveal" aria-label="Mục lục 7 bài">
            <div class="toc-title mono">Contents</div>
            {missions.map((mission) => (
              <a href={`#${mission.slug}`}><span class="toc-no">{mission.no}</span><span>{mission.label}</span><span>↘</span></a>
            ))}
          </aside>
          <div class="mission-list">
            {missions.map((mission, index) => (
              <article id={mission.slug} class="mission-card reveal" data-tint={mission.tint} data-even={index % 2 === 1 ? 'true' : 'false'} style={`transition-delay:${Math.min(index * .035, .20)}s`}>
                <div class="mission-top">
                  <div class="mission-number">{mission.no}<span>Task</span></div>
                  <div>
                    <span class="mission-label">{mission.label}</span>
                    <h3 class="mission-title">{mission.title}</h3>
                  </div>
                  <a class="action-link" href={mission.pdf} target="_blank" rel="noreferrer">Mở PDF ↗</a>
                </div>
                <div class="mission-command mono"><span class="prompt">$</span> {mission.command}</div>
                <div class="mission-body">
                  <div class="copy-block">
                    <div class="copy-note">
                      <span class="copy-kicker mono">Nội dung</span>
                      <p>{mission.summary}</p>
                    </div>
                    <div class="copy-note">
                      <span class="copy-kicker mono">Minh chứng</span>
                      <p>{mission.evidence}</p>
                    </div>
                    <div class="copy-note emphasis">
                      <span class="copy-kicker mono">Nhận xét cá nhân</span>
                      <p>{mission.insight}</p>
                    </div>
                    <div class="tool-list" aria-label="Công cụ sử dụng">
                      {mission.tools.map((tool) => <span class="tool">{tool}</span>)}
                    </div>
                  </div>
                  <div class="mission-panel">
                    <div class="panel-top">
                      <span class="panel-badge">Assessment Fit</span>
                      <a class="panel-cta" href={mission.pdf} target="_blank" rel="noreferrer">Xem minh chứng ↗</a>
                    </div>
                    <div class="panel-line"><div class="panel-key mono">Rubric</div><div class="panel-value">{mission.rubric}</div></div>
                    <div class="panel-line"><div class="panel-key mono">Status</div><div class="panel-value">Hoàn thành, có báo cáo PDF gốc và có thể đối chiếu ngay với yêu cầu đề bài.</div></div>
                    <div class="panel-line"><div class="panel-key mono">Value</div><div class="panel-value">Thể hiện kỹ năng số qua sản phẩm cụ thể, quy trình rõ ràng và khả năng tự phản tư sau khi hoàn thành.</div></div>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="ai" class="section container">
        <div class="section-head reveal">
          <div>
            <div class="kicker">Responsible AI</div>
            <h2>AI mạnh nhất khi được dùng minh bạch.</h2>
          </div>
          <p>
            Phần này bám sát yêu cầu về liêm chính học thuật: AI có thể hỗ trợ học tập, nhưng người học phải kiểm chứng, chỉnh sửa, ghi nhận và chịu trách nhiệm với sản phẩm cuối cùng.
          </p>
        </div>
        <div class="principles-grid">
          {principles.map(([name, note], index) => (
            <div class="principle reveal" style={`transition-delay:${Math.min(index * .045, .18)}s`}>
              <div class="check">✓</div>
              <strong>{name}</strong>
              <span>{note}</span>
            </div>
          ))}
        </div>
      </section>

      <section id="reflection" class="section container">
        <div class="section-head reveal">
          <div>
            <div class="kicker">Final Reflection</div>
            <h2>Tổng kết và đánh giá bản thân.</h2>
          </div>
          <p>
            Phần tổng kết không chỉ nhắc lại các bài đã làm, mà phân tích sự chuyển biến từ việc dùng công cụ rời rạc sang xây dựng một quy trình học tập số có kiểm soát.
          </p>
        </div>
        <div class="reflection-layout">
          <div class="reflection-visual reveal">
            <div class="mono">reflection.note</div>
            <h3>Từ người dùng công cụ sang người biết thiết kế quy trình học tập số.</h3>
          </div>
          <div class="glass-panel reflection-copy reveal" style="transition-delay:.06s">
            <p>
              Qua 7 bài thực hành, tôi nhận ra kỹ năng số không chỉ nằm ở việc biết sử dụng một phần mềm cụ thể, mà nằm ở khả năng xây dựng quy trình làm việc có kiểm soát: tổ chức file, tìm nguồn đáng tin cậy, đặt prompt rõ ràng, phối hợp nhóm, tạo sản phẩm và đánh giá rủi ro đạo đức.
            </p>
            <p>
              Thách thức lớn nhất là biến các nhiệm vụ rời rạc thành một hệ thống thống nhất. Portfolio này giải quyết điều đó bằng cách xem mỗi bài như một artifact trong hành trình học tập, có minh chứng, có công cụ và có phần phản tư cá nhân.
            </p>
            <p>
              Sau dự án, tôi có thể áp dụng các kỹ năng này vào nghiên cứu tài liệu, làm việc nhóm, chuẩn bị báo cáo học thuật và xây dựng các sản phẩm số trong tương lai. Đặc biệt, tôi hiểu rằng AI mạnh nhất khi được sử dụng minh bạch, có kiểm chứng và đặt dưới trách nhiệm của con người.
            </p>
          </div>
        </div>
      </section>

      <section id="rubric" class="section container">
        <div class="section-head reveal">
          <div>
            <div class="kicker">Assessment Map</div>
            <h2>Đối chiếu với rubric đánh giá.</h2>
          </div>
          <p>
            Bảng này cho thấy portfolio đáp ứng từng tiêu chí: từ thiết kế, cấu trúc, nhiệm vụ bắt buộc đến phần tổng kết và đánh giá bản thân.
          </p>
        </div>
        <div class="rubric-table">
          {rubric.map(([name, note], index) => (
            <div class="rubric-row reveal" style={`transition-delay:${Math.min(index * .025, .16)}s`}>
              <div class="rubric-name">{name}</div>
              <div class="rubric-note">{note}</div>
            </div>
          ))}
        </div>
      </section>
    </main>

    <footer class="footer container">
      <div class="footer-inner">
        <div>© 2026 · Trần Anh Đức · Portfolio Kỹ thuật số</div>
        <a href={student.github} target="_blank" rel="noreferrer">github.com/kieran-lucas ↗</a>
      </div>
    </footer>

    <script>
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const progress = document.querySelector('.progress');

      let scrollRaf = 0;
      const updateProgress = () => {
        if (!progress) return;
        const scrollTop = window.scrollY || document.documentElement.scrollTop;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const ratio = max > 0 ? Math.min(scrollTop / max, 1) : 0;
        progress.style.transform = `scaleX(${ratio})`;
      };
      const onScroll = () => {
        if (scrollRaf) return;
        scrollRaf = requestAnimationFrame(() => {
          updateProgress();
          updateActiveLink();
          scrollRaf = 0;
        });
      };

      const navLinks = [...document.querySelectorAll('.nav a')];
      const sectionMap = navLinks
        .map((link) => {
          const id = link.getAttribute('href')?.replace('#', '');
          return id ? [link, document.getElementById(id)] : null;
        })
        .filter(Boolean);

      const updateActiveLink = () => {
        const y = window.scrollY + 160;
        let currentId = sectionMap[0]?.[1]?.id;
        sectionMap.forEach(([, section]) => {
          if (section && y >= section.offsetTop) currentId = section.id;
        });
        navLinks.forEach((link) => link.classList.toggle('is-active', link.getAttribute('href') === `#${currentId}`));
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      updateProgress();
      updateActiveLink();

      if (!prefersReduced) {
        const items = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -6% 0px' });
        items.forEach((item) => observer.observe(item));
      } else {
        document.querySelectorAll('.reveal').forEach((item) => item.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
