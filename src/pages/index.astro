<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#eff8ff" />
    <meta
      name="description"
      content="Portfolio kỹ thuật số của Trần Anh Đức: website one-page cao cấp, mượt và có minh chứng cho 7 bài học chính về công nghệ số, AI, prompt engineering và liêm chính học thuật."
    />
    <title>Hành trình học tập số và ứng dụng AI — Trần Anh Đức</title>
    <link rel="preload" as="image" href="/assets/avatar-duc.webp" type="image/webp" />
    <link rel="preload" as="font" href="/fonts/Lexend-Regular.ttf" type="font/ttf" crossorigin />
    <link rel="preload" as="font" href="/fonts/Lexend-SemiBold.ttf" type="font/ttf" crossorigin />
    <style is:global>
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Light.ttf") format("truetype"); font-weight: 300; font-style: normal; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Regular.ttf") format("truetype"); font-weight: 400; font-style: normal; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Medium.ttf") format("truetype"); font-weight: 500; font-style: normal; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-SemiBold.ttf") format("truetype"); font-weight: 600; font-style: normal; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Bold.ttf") format("truetype"); font-weight: 700; font-style: normal; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-ExtraBold.ttf") format("truetype"); font-weight: 800; font-style: normal; font-display: swap; }

      :root {
        --ink: #071424;
        --ink-2: #193250;
        --muted: #6683a1;
        --muted-2: #8aa3bc;
        --surface: rgba(255, 255, 255, .64);
        --surface-strong: rgba(255, 255, 255, .78);
        --hairline: rgba(32, 140, 255, .18);
        --hairline-strong: rgba(22, 119, 255, .34);
        --blue: #007aff;
        --blue-2: #0a5dff;
        --cyan: #00d7ff;
        --aqua: #71efff;
        --indigo: #5f5cff;
        --violet: #8b5cf6;
        --teal: #14b8a6;
        --glow-blue: rgba(0, 122, 255, .26);
        --glow-cyan: rgba(0, 215, 255, .22);
        --shadow-lg: 0 34px 94px rgba(22, 119, 255, .16);
        --shadow-md: 0 22px 64px rgba(22, 119, 255, .12);
        --shadow-sm: 0 12px 36px rgba(22, 119, 255, .09);
        --radius-3xl: 42px;
        --radius-2xl: 32px;
        --radius-xl: 24px;
        --radius-lg: 18px;
        --container: 1208px;
        --topbar-h: 70px;
        --font-ui: "Lexend", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        --font-mono: "Cascadia Code", "JetBrains Mono", "SFMono-Regular", Consolas, monospace;
        --mx: 50%;
        --my: 20%;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; scroll-padding-top: 116px; }
      body {
        margin: 0;
        min-height: 100vh;
        color: var(--ink);
        font-family: var(--font-ui);
        font-size: 16px;
        line-height: 1.65;
        background:
          radial-gradient(circle at 14% -4%, rgba(0, 122, 255, .24), transparent 34rem),
          radial-gradient(circle at 88% 6%, rgba(0, 215, 255, .23), transparent 35rem),
          radial-gradient(circle at 68% 48%, rgba(111, 76, 255, .10), transparent 31rem),
          linear-gradient(180deg, #fbfdff 0%, #eef8ff 46%, #f8fcff 100%);
        overflow-x: hidden;
        text-rendering: optimizeLegibility;
        font-optical-sizing: auto;
        font-feature-settings: "kern" 1, "liga" 1, "calt" 1;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        z-index: -5;
        pointer-events: none;
        background-image:
          linear-gradient(rgba(0, 122, 255, .055) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 122, 255, .055) 1px, transparent 1px);
        background-size: 46px 46px;
        mask-image: linear-gradient(to bottom, rgba(0,0,0,.84), transparent 72%);
      }

      body::after {
        content: "";
        position: fixed;
        inset: -26vh -12vw auto -12vw;
        height: 78vh;
        z-index: -4;
        pointer-events: none;
        opacity: .94;
        filter: blur(16px) saturate(155%);
        background:
          radial-gradient(circle at 18% 42%, rgba(0, 122, 255, .22), transparent 24%),
          radial-gradient(circle at 46% 18%, rgba(0, 215, 255, .26), transparent 25%),
          radial-gradient(circle at 84% 50%, rgba(106, 92, 255, .18), transparent 25%),
          linear-gradient(90deg, transparent, rgba(255,255,255,.22), transparent);
        animation: aurora 16s ease-in-out infinite alternate;
      }

      a { color: inherit; text-decoration: none; }
      button, a { -webkit-tap-highlight-color: transparent; }
      ::selection { color: #fff; background: #007aff; }
      img { max-width: 100%; }
      .gpu { transform: translateZ(0); backface-visibility: hidden; }
      .container { width: min(var(--container), calc(100% - 44px)); margin: 0 auto; }
      .mono { font-family: var(--font-mono); letter-spacing: -0.02em; }
      main[id], section[id], article[id] { scroll-margin-top: 116px; }

      .orb-field {
        position: fixed;
        inset: 0;
        pointer-events: none;
        overflow: hidden;
        z-index: -3;
      }

      .orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(30px) saturate(155%);
        opacity: .52;
        will-change: transform;
      }

      .orb:nth-child(1) { width: 360px; height: 360px; left: -120px; top: 18vh; background: rgba(0,122,255,.20); animation: floatA 24s ease-in-out infinite; }
      .orb:nth-child(2) { width: 310px; height: 310px; right: -96px; top: 18vh; background: rgba(0,215,255,.19); animation: floatB 26s ease-in-out infinite; }
      .orb:nth-child(3) { width: 240px; height: 240px; left: 52%; bottom: 4vh; background: rgba(95,92,255,.12); animation: floatC 28s ease-in-out infinite; }
      .orb:nth-child(4) { width: 210px; height: 210px; left: 9%; bottom: 18vh; background: rgba(113,239,255,.14); animation: floatD 30s ease-in-out infinite; }

      .progress {
        position: fixed;
        inset: 0 0 auto 0;
        z-index: 1200;
        height: 3px;
        transform-origin: left;
        transform: scaleX(0);
        background: linear-gradient(90deg, #007aff, #00d7ff, #5f5cff);
        box-shadow: 0 0 22px rgba(0, 122, 255, .44);
      }

      .topbar {
        position: fixed;
        top: 14px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1100;
        width: min(var(--container), calc(100% - 28px));
        display: grid;
        grid-template-columns: max-content 1fr max-content;
        align-items: center;
        gap: 14px;
        min-height: var(--topbar-h);
        padding: 10px 12px 10px 14px;
        border: 1px solid rgba(255,255,255,.72);
        border-radius: 999px;
        background:
          linear-gradient(180deg, rgba(255,255,255,.84), rgba(229,247,255,.58)),
          radial-gradient(circle at 22% 0%, rgba(0,215,255,.22), transparent 38%),
          radial-gradient(circle at 90% 40%, rgba(0,122,255,.16), transparent 36%);
        backdrop-filter: blur(24px) saturate(180%);
        -webkit-backdrop-filter: blur(24px) saturate(180%);
        box-shadow:
          0 18px 48px rgba(0, 89, 210, .13),
          inset 0 1px 0 rgba(255,255,255,.94),
          inset 0 -1px 0 rgba(0,122,255,.08);
        isolation: isolate;
      }

      .topbar::before {
        content: "";
        position: absolute;
        inset: 1px;
        border-radius: inherit;
        pointer-events: none;
        background: linear-gradient(110deg, rgba(255,255,255,.52), transparent 40%, rgba(0,215,255,.08));
        z-index: -1;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 11px;
        min-width: max-content;
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        display: grid;
        place-items: center;
        border-radius: 16px;
        color: white;
        font-weight: 800;
        letter-spacing: -0.09em;
        background:
          radial-gradient(circle at 30% 20%, rgba(255,255,255,.55), transparent 31%),
          linear-gradient(135deg, #007aff 0%, #00d7ff 52%, #5f5cff 100%);
        box-shadow: 0 16px 34px rgba(0,122,255,.28), inset 0 1px 0 rgba(255,255,255,.44);
      }

      .brand-copy { display: grid; line-height: 1.1; }
      .brand-name { font-size: 14px; font-weight: 700; letter-spacing: -0.035em; }
      .brand-meta { margin-top: 3px; font-size: 11px; color: var(--muted); font-weight: 500; }

      .nav {
        justify-self: center;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 5px;
        border-radius: 999px;
        background: rgba(255,255,255,.48);
        border: 1px solid rgba(0,122,255,.09);
      }

      .nav a {
        position: relative;
        padding: 10px 12px;
        border-radius: 999px;
        color: #45617e;
        font-size: 12.5px;
        font-weight: 600;
        transition: color .18s ease, background .18s ease, transform .18s ease;
      }

      .nav a:hover,
      .nav a.is-active {
        color: #006cff;
        background: rgba(0,122,255,.09);
        transform: translateY(-1px);
      }

      .top-action {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        min-width: max-content;
        border-radius: 999px;
        padding: 11px 14px;
        color: white;
        background: linear-gradient(135deg, #007aff, #00c8ff 62%, #5f5cff);
        box-shadow: 0 16px 34px rgba(0,122,255,.26), inset 0 1px 0 rgba(255,255,255,.34);
        font-size: 12.5px;
        font-weight: 700;
      }

      .hero {
        position: relative;
        min-height: 100svh;
        display: grid;
        align-items: center;
        padding: 122px 0 70px;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.02fr) minmax(420px, .98fr);
        gap: 42px;
        align-items: center;
      }

      .hero-copy {
        position: relative;
        z-index: 2;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        padding: 9px 13px;
        border-radius: 999px;
        border: 1px solid rgba(0,122,255,.18);
        background: rgba(255,255,255,.66);
        backdrop-filter: blur(18px) saturate(180%);
        color: #005bd8;
        font-size: 12px;
        font-weight: 700;
        box-shadow: 0 10px 26px rgba(0,122,255,.08), inset 0 1px 0 rgba(255,255,255,.86);
      }

      .eyebrow::before {
        content: "";
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: #00d7ff;
