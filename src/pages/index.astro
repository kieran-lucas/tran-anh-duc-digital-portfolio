<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f2f9ff" />
    <meta name="description" content="Portfolio kỹ thuật số của Trần Anh Đức: 7 bài học chính về công nghệ số, AI và liêm chính học thuật." />
    <title>Hành trình học tập số và ứng dụng AI — Trần Anh Đức</title>
    <link rel="preload" as="image" href="/assets/avatar-duc.webp" type="image/webp" />
    <link rel="preload" as="font" href="/fonts/Lexend-Regular.ttf" type="font/ttf" crossorigin />
    <link rel="preload" as="font" href="/fonts/Lexend-SemiBold.ttf" type="font/ttf" crossorigin />
    <style is:global>
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Light.ttf") format("truetype"); font-weight: 300; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Regular.ttf") format("truetype"); font-weight: 400; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Medium.ttf") format("truetype"); font-weight: 500; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-SemiBold.ttf") format("truetype"); font-weight: 600; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-Bold.ttf") format("truetype"); font-weight: 700; font-display: swap; }
      @font-face { font-family: "Lexend"; src: url("/fonts/Lexend-ExtraBold.ttf") format("truetype"); font-weight: 800; font-display: swap; }
      :root {
        --ink:#071426; --ink-2:#203a59; --muted:#68839f; --blue:#007aff; --cyan:#0bd8ff; --violet:#5f5cff;
        --line:rgba(32,140,255,.16); --glass:rgba(255,255,255,.68); --glass-2:rgba(238,249,255,.56);
        --shadow:0 26px 82px rgba(0,122,255,.13); --soft:0 14px 44px rgba(0,122,255,.09);
        --container:1220px; --mono:"Cascadia Code","JetBrains Mono",ui-monospace,monospace;
      }
      *{box-sizing:border-box} html{scroll-behavior:smooth;scroll-padding-top:92px} body{margin:0;font-family:"Lexend",system-ui,sans-serif;color:var(--ink);background:radial-gradient(circle at 10% -6%,rgba(0,122,255,.25),transparent 34rem),radial-gradient(circle at 90% 4%,rgba(11,216,255,.24),transparent 34rem),linear-gradient(180deg,#fbfdff 0%,#eef8ff 46%,#f9fcff 100%);overflow-x:hidden;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility} body:before{content:"";position:fixed;inset:0;z-index:-3;pointer-events:none;background-image:linear-gradient(rgba(0,122,255,.052) 1px,transparent 1px),linear-gradient(90deg,rgba(0,122,255,.052) 1px,transparent 1px);background-size:46px 46px;mask-image:linear-gradient(to bottom,#000,transparent 72%)} a{color:inherit;text-decoration:none}.container{width:min(var(--container),calc(100% - 44px));margin:auto}.mono{font-family:var(--mono)}section[id],article[id]{scroll-margin-top:92px}.progress{position:fixed;inset:0 0 auto;height:3px;z-index:1200;transform-origin:left;transform:scaleX(0);background:linear-gradient(90deg,var(--blue),var(--cyan),var(--violet));box-shadow:0 0 20px rgba(0,122,255,.4)}
      .topbar{position:fixed;top:14px;left:50%;transform:translateX(-50%);z-index:1100;width:min(var(--container),calc(100% - 28px));min-height:70px;display:grid;grid-template-columns:max-content 1fr max-content;align-items:center;gap:14px;padding:10px 12px 10px 14px;border:1px solid rgba(255,255,255,.76);border-radius:999px;background:linear-gradient(180deg,rgba(255,255,255,.86),rgba(228,247,255,.6));backdrop-filter:blur(24px) saturate(180%);box-shadow:0 18px 50px rgba(0,89,210,.13),inset 0 1px 0 rgba(255,255,255,.94)}.brand{display:flex;align-items:center;gap:12px;min-width:max-content}.brand-mark{width:42px;height:42px;display:grid;place-items:center;border-radius:16px;color:white;font-weight:800;background:linear-gradient(135deg,var(--blue),var(--cyan) 55%,var(--violet));box-shadow:0 16px 34px rgba(0,122,255,.25)}.brand-name{display:block;font-weight:700;letter-spacing:-.04em}.brand-meta{display:block;margin-top:3px;color:var(--muted);font-size:11px;font-weight:500}.nav{justify-self:center;display:flex;gap:5px;padding:5px;border:1px solid rgba(0,122,255,.1);border-radius:999px;background:rgba(255,255,255,.55)}.nav a{padding:10px 13px;border-radius:999px;color:#496783;font-size:12.5px;font-weight:600;transition:background .18s ease,color .18s ease,transform .18s ease}.nav a:hover,.nav a.is-active{color:#006cff;background:rgba(0,122,255,.09);transform:translateY(-1px)}.top-action{border-radius:999px;padding:12px 16px;color:white;background:linear-gradient(135deg,var(--blue),var(--cyan) 60%,var(--violet));box-shadow:0 16px 34px rgba(0,122,255,.24);font-size:13px;font-weight:700}
      .hero{min-height:100svh;display:grid;align-items:center;padding:124px 0 72px}.hero-grid{display:grid;grid-template-columns:minmax(360px,.76fr) minmax(0,1.24fr);gap:clamp(56px,7vw,96px);align-items:center}.hero-visual{display:grid;align-content:center;gap:20px;min-height:650px;contain:layout paint}.hero-copy{position:relative;z-index:2}.eyebrow{display:inline-flex;align-items:center;gap:9px;padding:9px 13px;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.68);backdrop-filter:blur(16px);color:#005bd8;font-size:12px;font-weight:700}.eyebrow:before{content:"";width:8px;height:8px;border-radius:50%;background:var(--cyan);box-shadow:0 0 0 6px rgba(11,216,255,.14)}h1{margin:24px 0 20px;font-size:clamp(50px,6.2vw,88px);line-height:.99;letter-spacing:-.078em;font-weight:800}.gradient-text{color:transparent;background:linear-gradient(110deg,#05182b 0%,#006dff 34%,#04c5ff 58%,#5f5cff 80%,#071426 100%);background-size:210% 210%;-webkit-background-clip:text;background-clip:text;animation:gradientFlow 14s ease-in-out infinite alternate}.lead{max-width:720px;margin:0;color:var(--ink-2);font-size:clamp(17px,1.32vw,19px);line-height:1.9;font-weight:300;letter-spacing:-.02em}.hero-note{display:grid;grid-template-columns:54px 1fr;gap:14px;max-width:720px;margin-top:24px;padding:17px 18px;border:1px solid rgba(255,255,255,.78);border-radius:28px;background:linear-gradient(180deg,rgba(255,255,255,.74),rgba(233,247,255,.54));backdrop-filter:blur(18px);box-shadow:var(--soft),inset 0 1px 0 rgba(255,255,255,.9)}.hero-note-mark{display:grid;place-items:center;width:46px;height:46px;border-radius:16px;background:linear-gradient(135deg,rgba(0,122,255,.18),rgba(11,216,255,.28));color:#005bd8;font-family:var(--mono);font-size:13px;font-weight:800}.hero-note p{margin:0;color:#4b6884;font-size:14.1px;line-height:1.72}.identity-row{display:flex;flex-wrap:wrap;gap:9px;margin-top:26px}.pill{padding:8px 11px;border:1px solid rgba(0,122,255,.15);border-radius:999px;background:rgba(255,255,255,.66);color:#46647f;font-size:13px;font-weight:600;box-shadow:inset 0 1px 0 rgba(255,255,255,.86)}.hero-actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:32px}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:50px;padding:0 20px;border-radius:999px;font-size:14px;font-weight:700;transition:transform .2s ease,box-shadow .2s ease}.btn:hover{transform:translateY(-2px)}.btn-primary{color:#fff;background:linear-gradient(135deg,var(--blue),var(--cyan) 55%,var(--violet));box-shadow:0 20px 48px rgba(0,122,255,.25)}.btn-secondary{color:#005bd8;border:1px solid rgba(0,122,255,.2);background:rgba(255,255,255,.72)}
      .profile-card{position:relative;z-index:3;width:min(356px,calc(100% - 32px));padding:14px;border:1px solid rgba(255,255,255,.78);border-radius:34px;background:linear-gradient(180deg,rgba(255,255,255,.82),rgba(226,246,255,.58));backdrop-filter:blur(22px) saturate(180%);box-shadow:0 24px 66px rgba(0,122,255,.14),inset 0 1px 0 rgba(255,255,255,.92)}.profile-card:before{content:"";position:absolute;inset:-20px;z-index:-1;border-radius:46px;background:radial-gradient(circle at 30% 26%,rgba(11,216,255,.22),transparent 28%),radial-gradient(circle at 80% 0%,rgba(0,122,255,.2),transparent 26%);filter:blur(30px)}.avatar-frame{overflow:hidden;border-radius:26px;border:1px solid rgba(0,122,255,.12);aspect-ratio:1;background:white}.avatar-frame img{display:block;width:100%;height:100%;object-fit:cover;object-position:center;transform:scale(1.025)}.profile-meta{padding:15px 8px 4px}.profile-meta span{color:#006cff;font-size:11px;font-weight:800;letter-spacing:.14em;text-transform:uppercase}.profile-meta strong{display:block;margin-top:8px;font-size:20px;line-height:1.1;letter-spacing:-.05em}.profile-meta p{margin:8px 0 0;color:#5d7893;font-size:12.8px;line-height:1.6}.terminal-card{position:relative;z-index:2;width:calc(100% - 42px);max-width:390px;margin-left:42px;padding:14px;border:1px solid rgba(255,255,255,.76);border-radius:38px;background:linear-gradient(180deg,rgba(255,255,255,.76),rgba(222,246,255,.48));backdrop-filter:blur(20px) saturate(170%);box-shadow:var(--shadow),inset 0 1px 0 rgba(255,255,255,.9);transition:transform .25s ease}.terminal-card:hover{transform:translateY(-3px)}.terminal-window{overflow:hidden;border:1px solid rgba(0,122,255,.12);border-radius:28px;background:rgba(255,255,255,.66)}.terminal-bar{height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;border-bottom:1px solid rgba(0,122,255,.1)}.dots{display:flex;gap:7px}.dot{width:11px;height:11px;border-radius:50%;background:#bfdbfe}.dot:nth-child(1){background:#fecaca}.dot:nth-child(2){background:#fde68a}.dot:nth-child(3){background:#bbf7d0}.terminal-body{padding:20px;display:grid;gap:12px;contain:layout paint}.code-line{display:flex;gap:12px;padding:10px 0;border-bottom:1px solid rgba(0,122,255,.08);color:#243d58;font-family:var(--mono);font-size:12.8px;line-height:1.65}.code-line:last-child{border-bottom:0}.prompt{color:var(--blue);font-weight:800}.success{color:#079669;font-weight:800}.mini-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.mini-stat{padding:15px;border:1px solid rgba(0,122,255,.12);border-radius:20px;background:linear-gradient(180deg,rgba(255,255,255,.78),rgba(226,246,255,.54))}.mini-stat strong{display:block;font-size:23px;line-height:1;letter-spacing:-.05em}.mini-stat span{display:block;margin-top:6px;color:#5b7895;font-size:12px;font-weight:600}.mini-stat em{display:block;margin-top:3px;color:#8aa3bc;font-style:normal;font-size:11px}
      .section{padding:94px 0;content-visibility:auto;contain-intrinsic-size:1px 900px}.section-head{display:grid;grid-template-columns:.88fr 1fr;gap:38px;align-items:end;margin-bottom:34px}.kicker{display:inline-flex;align-items:center;gap:8px;color:#005bd8;font-size:12px;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.kicker:before{content:"";width:20px;height:2px;border-radius:999px;background:linear-gradient(90deg,var(--blue),var(--cyan))}h2{margin:10px 0 0;font-size:clamp(34px,4.2vw,58px);line-height:1.05;letter-spacing:-.06em;font-weight:800}.section-head p{margin:0;color:var(--ink-2);font-size:16.1px;line-height:1.84;font-weight:300}.glass,.mission-card,.rubric-row,.principle{position:relative;border:1px solid rgba(255,255,255,.74);border-radius:38px;background:linear-gradient(180deg,rgba(255,255,255,.72),rgba(230,247,255,.48));backdrop-filter:blur(18px) saturate(170%);box-shadow:var(--soft),inset 0 1px 0 rgba(255,255,255,.92)}.overview-grid{display:grid;grid-template-columns:1.06fr .94fr;gap:22px}.glass{padding:34px}.glass h3{margin:0 0 12px;font-size:26px;line-height:1.18;letter-spacing:-.048em}.glass p{margin:0;color:var(--ink-2);line-height:1.78;font-weight:300}.quality-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:18px}.quality-item{padding:15px;border:1px solid rgba(0,122,255,.12);border-radius:20px;background:rgba(255,255,255,.54)}.quality-item strong{display:block;color:#005bd8;font-size:14px}.quality-item span{display:block;margin-top:5px;color:#647f9b;font-size:12px;line-height:1.45}
      .mission-shell{display:grid;grid-template-columns:270px minmax(0,1fr);gap:24px;align-items:start}.toc{position:sticky;top:98px;padding:14px;border:1px solid rgba(255,255,255,.74);border-radius:30px;background:linear-gradient(180deg,rgba(255,255,255,.72),rgba(229,247,255,.52));backdrop-filter:blur(16px);box-shadow:var(--soft)}.toc-title{padding:8px 10px 12px;color:#006cff;font-size:12px;font-weight:800;letter-spacing:.12em;text-transform:uppercase}.toc a{display:grid;grid-template-columns:34px 1fr auto;align-items:center;gap:9px;min-height:46px;padding:8px 10px;border-radius:18px;color:#496885;font-size:12.5px;font-weight:600;transition:.18s ease}.toc a:hover{color:#005bd8;background:rgba(0,122,255,.08);transform:translateX(2px)}.toc-no{display:grid;place-items:center;width:32px;height:32px;border-radius:12px;background:rgba(255,255,255,.7);color:#007aff;font-family:var(--mono);font-size:11px;font-weight:800}.mission-list{display:grid;gap:26px}.mission-card{overflow:hidden;padding:28px;transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease;content-visibility:auto;contain-intrinsic-size:1px 520px}.mission-card:hover{transform:translateY(-4px);border-color:rgba(0,122,255,.32);box-shadow:0 32px 90px rgba(0,122,255,.15),inset 0 1px 0 rgba(255,255,255,.94)}.mission-top{display:grid;grid-template-columns:106px minmax(0,1fr) max-content;gap:20px;align-items:start}.mission-number{display:grid;place-items:center;width:96px;height:96px;border:1px solid rgba(0,122,255,.15);border-radius:30px;background:linear-gradient(145deg,rgba(255,255,255,.94),rgba(220,245,255,.74));color:#006cff;font-family:var(--mono);font-size:32px;font-weight:800;letter-spacing:-.08em}.mission-label{display:inline-flex;align-items:center;gap:8px;padding:8px 11px;border:1px solid rgba(0,122,255,.14);border-radius:999px;background:rgba(255,255,255,.6);color:#006cff;font-size:12px;font-weight:800}.mission-title{margin:12px 0 0;font-size:clamp(23px,2.35vw,34px);line-height:1.18;letter-spacing:-.055em;font-weight:800}.action-link{display:inline-flex;align-items:center;justify-content:center;min-width:max-content;padding:11px 14px;border-radius:999px;color:#fff;background:linear-gradient(135deg,var(--blue),var(--cyan) 60%,var(--violet));box-shadow:0 16px 36px rgba(0,122,255,.2);font-size:13px;font-weight:700}.mission-body{display:grid;grid-template-columns:minmax(0,1.12fr) minmax(280px,.88fr);gap:22px;margin-top:22px}.copy-block{display:grid;gap:12px}.copy-note{padding:16px 18px;border:1px solid rgba(0,122,255,.1);border-radius:24px;background:linear-gradient(180deg,rgba(255,255,255,.62),rgba(238,249,255,.42))}.copy-kicker{display:block;margin-bottom:8px;color:#006cff;font-family:var(--mono);font-size:11px;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.copy-note p{margin:0;color:#344f69;font-size:15px;line-height:1.8;font-weight:300}.tool-list{display:flex;flex-wrap:wrap;gap:8px}.tool{padding:7px 10px;border:1px solid rgba(0,122,255,.13);border-radius:999px;background:rgba(255,255,255,.62);color:#4f6b87;font-size:12px;font-weight:700}.mission-panel{padding:18px;border:1px solid rgba(0,122,255,.13);border-radius:30px;background:linear-gradient(180deg,rgba(255,255,255,.64),rgba(230,247,255,.48))}.panel-top{display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:12px;margin-bottom:8px}.panel-badge,.panel-cta{padding:8px 11px;border-radius:999px;background:rgba(255,255,255,.72);color:#006cff;font-size:11.5px;font-weight:800}.panel-line{display:grid;grid-template-columns:84px 1fr;gap:12px;padding:13px 0;border-bottom:1px solid rgba(0,122,255,.08)}.panel-line:last-child{border-bottom:0}.panel-key{color:#006cff;font-family:var(--mono);font-size:11px;font-weight:800;text-transform:uppercase}.panel-value{color:#526f8c;font-size:13.5px;line-height:1.6}
      .principles-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}.principle{min-height:210px;padding:20px}.check{width:42px;height:42px;display:grid;place-items:center;border-radius:16px;color:#fff;background:linear-gradient(135deg,var(--blue),var(--cyan));font-weight:800;margin-bottom:16px}.principle strong{display:block;font-size:17px;line-height:1.25;letter-spacing:-.04em}.principle span{display:block;margin-top:10px;color:#577491;font-size:13.2px;line-height:1.64;font-weight:300}.reflection-layout{display:grid;grid-template-columns:.86fr 1.14fr;gap:18px}.reflection-visual{min-height:380px;padding:34px;border-radius:42px;color:white;background:linear-gradient(135deg,var(--blue),var(--cyan) 52%,var(--violet));box-shadow:0 36px 95px rgba(0,122,255,.24)}.reflection-visual h3{margin:20px 0 0;font-size:clamp(30px,3.4vw,44px);line-height:1.08;letter-spacing:-.066em}.reflection-copy{display:grid;gap:13px}.reflection-copy p{margin:0;color:#334f69;font-size:15.55px;line-height:1.82;font-weight:300}.rubric-table{display:grid;gap:11px}.rubric-row{display:grid;grid-template-columns:270px 1fr;gap:16px;padding:16px;border-radius:22px}.rubric-name{font-weight:800;letter-spacing:-.036em}.rubric-note{color:#5b7895;line-height:1.62;font-size:14px}.footer{padding:48px 0 64px}.footer-inner{display:flex;justify-content:space-between;gap:18px;padding-top:26px;border-top:1px solid rgba(0,122,255,.14);color:#6683a1;font-size:14px}.footer a{color:#006cff;font-weight:700}.reveal{opacity:0;transform:translateY(18px);transition:opacity .62s ease,transform .62s cubic-bezier(.2,.8,.2,1)}.reveal.is-visible{opacity:1;transform:none}@keyframes gradientFlow{from{background-position:0% 50%}to{background-position:100% 50%}}
      @media (max-width:1050px){.topbar{grid-template-columns:max-content 1fr}.nav{display:none}.hero-grid,.section-head,.overview-grid,.mission-shell,.reflection-layout{grid-template-columns:1fr}.hero-visual{min-height:auto;display:grid;gap:20px}.profile-card,.terminal-card{width:100%;max-width:none;margin-left:0;transform:none}.principles-grid{grid-template-columns:repeat(2,1fr)}.toc{position:relative;top:0;display:grid;grid-template-columns:repeat(2,1fr)}.toc-title{grid-column:1/-1}.mission-body{grid-template-columns:1fr}}
      @media (max-width:720px){.container{width:min(100% - 28px,var(--container))}.topbar{top:10px;width:calc(100% - 20px);min-height:62px}.brand-meta,.top-action{display:none}.hero{padding-top:104px}.hero-grid{gap:28px}h1{font-size:clamp(42px,12vw,64px);letter-spacing:-.064em}.lead{font-size:15.8px}.hero-note{grid-template-columns:1fr}.mini-stats,.quality-strip,.principles-grid{grid-template-columns:1fr}.mission-top{grid-template-columns:1fr}.rubric-row{grid-template-columns:1fr}.footer-inner{flex-direction:column}.glass,.mission-card,.reflection-visual{border-radius:30px;padding:20px}}
      @media (prefers-reduced-motion:reduce){*,*:before,*:after{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important;scroll-behavior:auto!important}.reveal{opacity:1;transform:none}}
    </style>
