    <script>
      const progress=document.querySelector('.progress');let raf=0;const navLinks=[...document.querySelectorAll('.nav a')];const sectionMap=navLinks.map((link)=>{const id=link.getAttribute('href')?.replace('#','');return id?[link,document.getElementById(id)]:null}).filter(Boolean);document.querySelectorAll('a[href^="#"]').forEach((a)=>a.addEventListener('click',(e)=>{const h=a.getAttribute('href');if(!h||h==='#')return;const t=h==='#top'?document.getElementById('top'):document.querySelector(h);if(!t)return;e.preventDefault();const y=h==='#top'?0:t.getBoundingClientRect().top+window.scrollY-92;window.scrollTo({top:Math.max(0,y),behavior:'smooth'});history.replaceState(null,'',h)}));function tick(){const top=window.scrollY||document.documentElement.scrollTop;const max=document.documentElement.scrollHeight-window.innerHeight;progress.style.transform=`scaleX(${max>0?Math.min(top/max,1):0})`;let current=sectionMap[0]?.[1]?.id;sectionMap.forEach(([,s])=>{if(s&&top+100>=s.offsetTop)current=s.id});navLinks.forEach((l)=>l.classList.toggle('is-active',l.getAttribute('href')===`#${current}`));raf=0}function onScroll(){if(!raf)raf=requestAnimationFrame(tick)}window.addEventListener('scroll',onScroll,{passive:true});tick();if(!window.matchMedia('(prefers-reduced-motion: reduce)').matches){const obs=new IntersectionObserver((entries)=>{entries.forEach((e)=>{if(e.isIntersecting){e.target.classList.add('is-visible');obs.unobserve(e.target)}})},{threshold:.12,rootMargin:'0px 0px -6% 0px'});document.querySelectorAll('.reveal').forEach((el)=>obs.observe(el))}else{document.querySelectorAll('.reveal').forEach((el)=>el.classList.add('is-visible'))}
    </script>
